<div class="p-6">
  <h1 class="text-2xl font-bold mb-6 text-white bg-gradient-to-r from-blue-500 to-blue-400 p-4 rounded shadow-lg">
    Sectors
  </h1>

  <%= link_to "New Sector", new_admin_company_sector_path(@company), class: "px-4 py-2 bg-gradient-to-r from-blue-400 to-blue-600 text-white rounded shadow hover:opacity-90 transition mb-4 inline-block" %>

  <table class="w-full bg-white rounded shadow overflow-hidden">
    <thead class="bg-blue-500 text-white">
      <tr>
        <th class="px-4 py-2">Name</th>
        <th class="px-4 py-2">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @sectors.each do |sector| %>
        <tr class="border-b">
          <td class="px-4 py-2"><%= sector.name %></td>
          <td class="px-4 py-2 space-x-2">
            <%= link_to "Edit", edit_admin_sector_path(sector), class: "px-2 py-1 bg-blue-400 text-white rounded hover:opacity-90 transition" %>
            <%= link_to "Delete", admin_sector_path(sector), method: :delete, data: { confirm: "Are you sure?" }, class: "px-2 py-1 bg-red-500 text-white rounded hover:opacity-90 transition" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>