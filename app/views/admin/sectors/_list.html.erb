<div class="bg-gray-700 p-4 rounded-lg shadow-inner mt-2">
  <h3 class="text-white font-semibold mb-2">Sectors</h3>
  <% sectors.each do |sector| %>
    <div class="flex justify-between items-center text-white mb-1">
      <span><%= sector.name %></span>
      <div class="flex gap-2">
        <%= link_to "Edit", edit_admin_sector_path(sector),
                    class: "px-2 py-1 bg-yellow-500 rounded hover:bg-yellow-600" %>
        <%= link_to "Delete", admin_sector_path(sector),
                    method: :delete,
                    data: { confirm: "Are you sure?" },
                    class: "px-2 py-1 bg-red-500 rounded hover:bg-red-600" %>
      </div>
    </div>
  <% end %>
</div>