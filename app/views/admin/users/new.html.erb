<!-- app/views/admin/users/_form.html.erb -->
<%= form_with model: @user, url: @user.persisted? ? admin_user_path(@user) : admin_company_users_path(@company), local: true, class: "space-y-4 bg-white p-6 rounded shadow" do |f| %>
  <div>
    <%= f.label :name, class: "block font-medium mb-1" %>
    <%= f.text_field :name, class: "border px-3 py-2 rounded w-full", required: true %>
  </div>

  <div>
    <%= f.label :email, class: "block font-medium mb-1" %>
    <%= f.email_field :email, class: "border px-3 py-2 rounded w-full", required: true %>
  </div>

  <div>
    <%= f.label :role, class: "block font-medium mb-1" %>
    <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] },
                 {}, class: "border px-3 py-2 rounded w-full" %>
  </div>
  <div>
  <%= f.label :company_id, "Company", class: "block font-medium mb-1" %>
  <%= f.collection_select :company_id, @companies, :id, :name, { prompt: "Select Company" },
                          class: "border px-3 py-2 rounded w-full",
                          selected: @user.company_id %>
</div>

<div>
  <%= f.label :sector_id, "Sector", class: "block font-medium mb-1" %>
  <%= f.collection_select :sector_id, @sectors, :id, :name, { prompt: "Select Sector" },
                          class: "border px-3 py-2 rounded w-full",
                          selected: @user.sector_id %>
</div>

  <div>
  <%= f.label :manager_id, "Manager", class: "block font-medium mb-1" %>
  <%= f.collection_select :manager_id, @managers, :id, :name, { prompt: "Select Manager" },
                          class: "border px-3 py-2 rounded w-full",
                          selected: @user.manager_id %>
</div>

 <%= f.label :password %>
  <%= f.password_field :password, class: "border p-1 rounded" %>
</div>

<div>
  <%= f.label :password_confirmation %>
  <%= f.password_field :password_confirmation, class: "border p-1 rounded" %>
</div>

  <div>
    <%= f.submit @user.persisted? ? "Update User" : "Create User",
                 class: "bg-gradient-to-r from-blue-400 to-blue-600 text-white px-4 py-2 rounded hover:from-blue-500 hover:to-blue-700" %>
  </div>
<% end %>