<div class="bg-gray-700 p-4 rounded-lg shadow-inner mt-2">
  <h3 class="text-white font-semibold mb-2">Users</h3>
  <% users.each do |user| %>
    <div class="flex justify-between items-center text-white mb-1">
      <span><%= user.name %> (<%= user.role.titleize %>)</span>
      <div class="flex gap-2">
        <%= link_to "Edit", edit_admin_company_user_path(user.company, user),
                    class: "px-2 py-1 bg-yellow-500 rounded hover:bg-yellow-600" %>
        <%= link_to "Delete", admin_company_user_path(user.company, user),
                    method: :delete,
                    data: { confirm: "Are you sure?" },
                    class: "px-2 py-1 bg-red-500 rounded hover:bg-red-600" %>
      </div>
    </div>
  <% end %>
</div>