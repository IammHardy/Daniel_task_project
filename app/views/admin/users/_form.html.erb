<%= form_with(model: [:admin, @user], local: true) do |f| %>
  <%= f.label :name %>
  <%= f.text_field :name %>

  <%= f.label :email %>
  <%= f.email_field :email %>

  <%= f.label :role %>
  <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] } %>

  <%= f.label :sector_id, "Sector" %>
  <%= f.collection_select :sector_id, @company.sectors, :id, :name, include_blank: true %>

  <%= f.label :manager_id, "Manager" %>
  <%= f.collection_select :manager_id, @company.users.where(role: :manager), :id, :name, include_blank: true %>

  <%= f.label :password %>
  <%= f.password_field :password %>

  <%= f.label :password_confirmation %>
  <%= f.password_field :password_confirmation %>

  <%= f.submit %>
<% end %>