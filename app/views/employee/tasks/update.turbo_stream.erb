<%= turbo_stream.replace "task_#{@task.id}" do %>
  <div class="bg-gray-800 p-4 rounded mb-3 flex justify-between items-center">
    <div>
      <p class="font-semibold"><%= @task.title %></p>
      <p class="text-sm text-gray-400">
        Due: <%= @task.due_date&.strftime("%d %b %Y") || "No deadline" %>
      </p>
    </div>

    <span class="<%= @task.completed? ? 'text-green-400' : 'text-yellow-400' %>">
      <%= @task.completed? ? "Completed" : "Pending" %>
    </span>

    <% unless @task.completed? %>
      <%= button_to "✔",
          employee_task_path(@task),
          method: :patch,
          form: { "data-turbo-stream" => true },
          class: "px-2 py-1 bg-green-600 rounded text-xs hover:bg-green-700" %>
    <% end %>
  </div>
<% end %>