<div class="min-h-screen bg-gray-900 text-white p-6">

  <h1 class="text-2xl font-bold mb-6 text-purple-400">
    My Tasks
  </h1>

  <% if @tasks.any? %>
    <div class="grid gap-4">
      <% @tasks.each do |task| %>
        <div class="bg-gray-800 p-4 rounded-xl shadow hover:shadow-lg transition flex justify-between items-center">

          <div>
            <h2 class="text-lg font-semibold">
              <%= task.title %>
            </h2>

            <p class="text-sm text-gray-400">
              Due: <%= task.due_date&.strftime("%d %b %Y") || "No deadline" %>
            </p>
          </div>

          <div class="flex items-center gap-3">
            <!-- Status Badge -->
            <span class="px-3 py-1 text-xs rounded-full
              <%= task.completed? ? 'bg-green-600' : 'bg-yellow-500' %>">
              <%= task.completed? ? "Completed" : "Pending" %>
            </span>

            <!-- View Button -->
            <%= link_to "View",
                employee_task_path(task),
                class: "px-3 py-1 bg-purple-500 rounded hover:opacity-90" %>
          </div>
          <% unless task.completed? %>
  <%= button_to "✔",
      employee_task_path(task),
      method: :patch,
      class: "px-2 py-1 bg-green-600 rounded text-xs hover:bg-green-700" %>
<% end %>

        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-400">No tasks assigned yet.</p>
  <% end %>

</div>