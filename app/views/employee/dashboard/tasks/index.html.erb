<h1>My Tasks</h1>

<% if @tasks.any? %>
  <table>
    <thead>
      <tr>
        <th>Title</th>
        <th>Sector</th>
        <th>Manager</th>
        <th>Status</th>
        <th>Priority</th>
        <th>Due Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @tasks.each do |task| %>
        <tr>
          <td><%= task.title %></td>
          <td><%= task.sector.name %></td>
          <td><%= task.manager.name %></td>
          <td><%= task.status.titleize %></td>
          <td><%= task.priority.titleize %></td>
          <td><%= task.due_date %></td>
          <td><%= link_to "View", employees_task_path(task) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No tasks assigned to you yet.</p>
<% end %>