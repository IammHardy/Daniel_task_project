<% flash.each do |type, message| %>
  <% next if message.blank? %>

  <% css_classes =
    case type.to_sym
    when :notice
      "bg-green-600 border-green-400 text-white"
    when :alert
      "bg-red-600 border-red-400 text-white"
    else
      "bg-blue-600 border-blue-400 text-white"
    end
  %>

  <div class="rounded-lg border-l-4 px-4 py-3 shadow-lg <%= css_classes %>">
    <div class="flex items-start justify-between gap-3">
      <p class="text-sm font-medium"><%= message %></p>
      <button
        type="button"
        onclick="this.closest('div.rounded-lg').remove()"
        class="text-white text-lg leading-none opacity-80 hover:opacity-100"
      >
        &times;
      </button>
    </div>
  </div>
<% end %>