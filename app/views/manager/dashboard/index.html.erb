<div class="min-h-screen bg-gray-900 text-white font-sans">

  <!-- Header -->
  <header class="flex justify-between items-center p-4 bg-gradient-to-r from-green-500 to-green-400 shadow-lg">
    <h1 class="text-2xl md:text-3xl font-bold">
      Manager Dashboard
    </h1>

    <div class="flex items-center space-x-4">
      <span class="font-medium">
        👋 <%= current_user.name %>
      </span>

      <%= button_to "Logout",
          destroy_user_session_path,
          method: :delete,
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 rounded shadow transition" %>
    </div>
  </header>

  <!-- Main Content -->
  <main class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

    <!-- Tasks Card -->
    <div class="bg-gray-800 p-6 rounded-xl shadow hover:shadow-xl transition">
      <h2 class="text-xl font-bold mb-4 text-green-400">Tasks</h2>

      <%= link_to "View Tasks",
          manager_tasks_path,
          class: "block mb-2 px-4 py-2 bg-green-500 rounded hover:opacity-90" %>

      <%= link_to "Create Task",
          new_manager_task_path,
          class: "block px-4 py-2 bg-blue-500 rounded hover:opacity-90" %>
    </div>

    <!-- Team Card -->
    <div class="bg-gray-800 p-6 rounded-xl shadow hover:shadow-xl transition">
      <h2 class="text-xl font-bold mb-4 text-green-400">My Team</h2>

      <p class="text-gray-300 text-sm">
        Manage employees assigned to you.
      </p>

      <!-- You can hook this later -->
      <button class="mt-3 px-4 py-2 bg-gray-600 rounded opacity-60 cursor-not-allowed">
        Coming Soon
      </button>
    </div>

    <!-- Profile Card -->
    <div class="bg-gray-800 p-6 rounded-xl shadow hover:shadow-xl transition">
      <h2 class="text-xl font-bold mb-4 text-green-400">Profile</h2>

      <p><strong>Name:</strong> <%= current_user.name %></p>
      <p><strong>Email:</strong> <%= current_user.email %></p>

      <%= link_to "Edit Profile",
          edit_user_registration_path,
          class: "inline-block mt-3 px-4 py-2 bg-purple-500 rounded hover:opacity-90" %>
    </div>

  </main>
</div>